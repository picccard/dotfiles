{{- $desiredHostname := promptStringOnce . "hostname" "What desired hostname to use" -}}
{{- $githubNoreplyEmail := promptStringOnce . "githubNoreplyEmail" "What GitHub noreply mail to use" -}}
{{- $githubSigningkey := promptStringOnce . "githubSigningkey" "What gpg keyid to use" -}}

[data]
    desiredHostname = "{{ $desiredHostname }}"
    githubNoreplyEmail = "{{ $githubNoreplyEmail }}"
    githubSigningkey = "{{ $githubSigningkey }}"
